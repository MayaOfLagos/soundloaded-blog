# ─── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3002
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com
NEXT_PUBLIC_APP_NAME="Soundloaded Blog"
NODE_ENV=development

# ─── Database (PostgreSQL) ────────────────────────────────────────────
# Local Docker (port 5433 — avoids conflict with soundloaded-db on 5432)
DATABASE_URL="postgresql://soundloadedblog:soundloadedblog_dev@localhost:5433/soundloadedblog?schema=public"
# Docker compose env
POSTGRES_USER=soundloadedblog
POSTGRES_PASSWORD=soundloadedblog_dev
POSTGRES_DB=soundloadedblog

# Production (Neon):
# DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/soundloadedblog?sslmode=require"

# ─── Authentication (Auth.js / NextAuth) ──────────────────────────────
NEXTAUTH_URL=http://localhost:3002
# Generate with: openssl rand -hex 32
AUTH_SECRET=replace_with_openssl_rand_hex_32

# ─── Payload CMS ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
PAYLOAD_SECRET=replace_with_another_openssl_rand_hex_32

# ─── Cloudflare R2 ────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_MEDIA_BUCKET=soundloadedblog-media
R2_MUSIC_BUCKET=soundloadedblog-music
NEXT_PUBLIC_CDN_URL=https://cdn.soundloaded.ng
NEXT_PUBLIC_MUSIC_CDN_URL=https://music.soundloaded.ng

# ─── Redis (Upstash for prod / local Docker on port 6380) ─────────────
# Local Docker:
REDIS_URL=redis://:soundloadedblog_redis@localhost:6380
REDIS_PASSWORD=soundloadedblog_redis
# Production (Upstash):
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ─── Meilisearch ──────────────────────────────────────────────────────
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_ADMIN_KEY=soundloadedblog_search_key
MEILI_MASTER_KEY=soundloadedblog_search_key
NEXT_PUBLIC_MEILISEARCH_HOST=http://localhost:7700
NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY=your_search_only_api_key

# ─── Email (Resend) ───────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=noreply@soundloaded.ng
RESEND_NEWSLETTER_FROM=newsletter@soundloaded.ng

# ─── Error Monitoring (Sentry) ────────────────────────────────────────
SENTRY_DSN=https://your_key@sentry.io/project_id
NEXT_PUBLIC_SENTRY_DSN=https://your_key@sentry.io/project_id
SENTRY_AUTH_TOKEN=your_sentry_auth_token
SENTRY_ORG=soundloadedblog
SENTRY_PROJECT=soundloadedblog-blog

# ─── Analytics (Umami — self-hosted) ─────────────────────────────────
NEXT_PUBLIC_UMAMI_WEBSITE_ID=your_umami_site_id
NEXT_PUBLIC_UMAMI_URL=https://analytics.soundloaded.ng

# ─── Cloudflare Turnstile (bot protection on login) ───────────────────
# Create a site at dash.cloudflare.com > Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# ─── Admin Portal ─────────────────────────────────────────────────────
# Secret URL path for the admin login page (e.g. /backstage, /editorial)
ADMIN_LOGIN_PATH=/lcs_admin
# Generate with: openssl rand -hex 32
ADMIN_PORTAL_SECRET=replace_with_openssl_rand_hex_32
# Optional comma-separated IP whitelist (leave empty to allow any IP)
ADMIN_IP_WHITELIST=
