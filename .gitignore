# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit real secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example is safe to commit (no real values)

# Payload CMS media uploads (local)
/media/

# Docker local data volumes
/docker/data/

# Prisma dev db
prisma/dev.db
prisma/dev.db-journal

# Generated Payload types (regenerate with pnpm payload:generate)
src/payload/payload-types.ts

# WordPress import parsed data (large JSON files)
scripts/wp-data/

# vercel
.vercel

# IDE
.vscode/

# typescript
*.tsbuildinfo
next-env.d.ts
.claude/
