generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users ─────────────────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          UserRole  @default(READER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bio         String?
  location    String?
  socialLinks Json?

  posts                     Post[]
  pages                     Page[]                     @relation("PageAuthor")
  comments                  Comment[]
  downloads                 Download[]
  accounts                  Account[]
  sessions                  Session[]
  media                     Media[]
  pushSubscriptions         PushSubscription[]
  subscription              Subscription?
  transactions              Transaction[]
  searchQueries             SearchQuery[]
  interactionEvents         InteractionEvent[]         @relation("InteractionEventUser")
  recommendationImpressions RecommendationImpression[] @relation("RecommendationImpressionUser")
  affinitySnapshots         UserAffinitySnapshot[]
  bookmarks                 Bookmark[]
  favorites                 Favorite[]
  reactions                 Reaction[]
  following                 Follow[]                   @relation("UserFollowing")
  followers                 Follow[]                   @relation("UserFollowers")
  artistFollows             ArtistFollow[]
  stories                   Story[]
  storyViews                StoryView[]
  notifications             Notification[]             @relation("NotificationsReceived")
  triggeredNotifications    Notification[]             @relation("NotificationsTriggered")
  preferences               UserPreferences?
  hiddenPosts               HiddenPost[]
  reports                   Report[]
  commentLikes              CommentLike[]
  postViews                 PostView[]
  blocking                  UserBlock[]                @relation("UserBlocking")
  blockedBy                 UserBlock[]                @relation("UserBlocked")
  artistProfile             Artist?                    @relation("UserArtistProfile")
  labelProfile              Label?                     @relation("UserLabelProfile")
  playlists                 Playlist[]
  creatorApplications       CreatorApplication[]
  reviewedApplications      CreatorApplication[]       @relation("ApplicationReviewer")
}

enum UserRole {
  READER
  CONTRIBUTOR
  EDITOR
  ADMIN
  SUPER_ADMIN
}

// ── Posts ─────────────────────────────────────────────────────────────
model Post {
  id            String     @id @default(cuid())
  title         String
  slug          String     @unique
  excerpt       String?
  body          Json
  coverImage    String?
  status        PostStatus @default(DRAFT)
  type          PostType   @default(NEWS)
  publishedAt   DateTime?
  views         Int        @default(0)
  wpPostId      Int?       @unique // WordPress post ID for import tracing
  bloggerPostId String?    @unique // Blogger post ID for import tracing
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  authorId        String
  author          User       @relation(fields: [authorId], references: [id])
  categoryId      String?
  category        Category?  @relation(fields: [categoryId], references: [id])
  tags            PostTag[]
  comments        Comment[]
  music           Music?
  enableDownload  Boolean    @default(false)
  downloadLabel   String?
  downloadCount   Int        @default(0)
  downloadMediaId String?
  downloadMedia   Media?     @relation("PostDownloadMedia", fields: [downloadMediaId], references: [id], onDelete: SetNull)
  bookmarks       Bookmark[]
  favorites       Favorite[]
  reactions       Reaction[]

  // SEO overrides (optional — auto-generated from title/excerpt if empty)
  metaTitle       String?
  metaDescription String?
  focusKeyword    String?

  // User-generated content (feed posts by contributors)
  isUserGenerated  Boolean      @default(false)
  mediaAttachments Json         @default("[]") // Array of { url, type, key } for feed post media
  hiddenBy         HiddenPost[]
  reports          Report[]
  postViews        PostView[]

  @@index([slug])
  @@index([status, publishedAt])
  @@index([type, publishedAt])
  @@index([downloadMediaId])
  @@index([isUserGenerated, status, createdAt])
}

enum PostStatus {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

enum PostType {
  NEWS
  MUSIC
  GIST
  ALBUM
  VIDEO
  LYRICS
  COMMUNITY
}

model Page {
  id      String  @id @default(cuid())
  title   String
  slug    String  @unique
  excerpt String?
  body    Json

  coverImage  String?
  status      PostStatus @default(DRAFT)
  template    String     @default("DEFAULT") // DEFAULT | LEGAL | CONTACT | FULL_WIDTH
  publishedAt DateTime?
  views       Int        @default(0)

  authorId String?
  author   User?   @relation("PageAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  showInHeader Boolean @default(false)
  showInFooter Boolean @default(false)
  sortOrder    Int     @default(0)

  isSystem  Boolean @default(false)
  systemKey String? @unique

  metaTitle       String?
  metaDescription String?
  focusKeyword    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([status, publishedAt])
  @@index([showInHeader, sortOrder])
  @@index([showInFooter, sortOrder])
  @@index([systemKey])
}

// ── Music ─────────────────────────────────────────────────────────────
model Music {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  r2Key          String
  filename       String
  fileSize       BigInt
  duration       Int?
  format         String
  bitrate        Int?
  coverArt       String?
  downloadCount  Int      @default(0)
  streamCount    Int      @default(0)
  year           Int?
  genre          String?
  label          String?
  isExclusive    Boolean  @default(false)
  enableDownload Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  trackNumber Int?

  // ── Audio processing fields ──
  processedR2Key   String? // R2 key for the processed (transcoded) file
  processedFormat  String? // e.g. "aac", "mp3"
  processedBitrate Int? // e.g. 128, 256
  processedSize    BigInt? // file size of processed version
  loudnessLUFS     Float? // integrated loudness (EBU R128)
  waveformData     Json? // array of amplitude peaks for waveform UI
  processingStatus String  @default("pending") // pending | processing | completed | failed
  processingError  String? // error message if processing failed

  processingJobs AudioProcessingJob[]

  postId         String          @unique
  post           Post            @relation(fields: [postId], references: [id])
  artistId       String
  artist         Artist          @relation(fields: [artistId], references: [id])
  albumId        String?
  album          Album?          @relation(fields: [albumId], references: [id])
  downloads      Download[]
  transactions   Transaction[]
  price          Int? // kobo, null = use default

  // ── Monetization ──
  accessModel  String  @default("free") // "free" | "subscription" | "purchase" | "both"
  streamAccess String  @default("free") // "free" | "subscription"
  creatorPrice Int?                     // kobo — creator-set per-purchase price

  bookmarks      Bookmark[]
  favorites      Favorite[]
  playlistTracks PlaylistTrack[]

  @@index([slug])
  @@index([artistId])
}

// ── Artists ───────────────────────────────────────────────────────────
model Artist {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  bio        String?
  photo      String?
  coverImage String?
  country    String?  @default("Nigeria")
  genre      String?
  instagram  String?
  twitter    String?
  facebook   String?
  spotify    String?
  appleMusic String?
  youtube    String?
  tiktok     String?
  soundcloud String?
  boomplay   String?
  website    String?
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  ownerId String? @unique
  owner   User?   @relation("UserArtistProfile", fields: [ownerId], references: [id], onDelete: SetNull)
  labelId String?
  label   Label?  @relation(fields: [labelId], references: [id], onDelete: SetNull)

  music         Music[]
  albums        Album[]
  artistFollows ArtistFollow[]

  @@index([slug])
  @@index([ownerId])
  @@index([labelId])
}

// ── Labels ────────────────────────────────────────────────────────────
model Label {
  id         String   @id @default(cuid())
  name       String
  slug       String   @unique
  bio        String?
  logo       String?
  coverImage String?
  country    String?  @default("Nigeria")
  website    String?
  instagram  String?
  twitter    String?
  facebook   String?
  spotify    String?
  appleMusic String?
  verified   Boolean  @default(false)
  ownerId    String?  @unique
  owner      User?    @relation("UserLabelProfile", fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  artists Artist[]

  @@index([slug])
  @@index([ownerId])
}

// ── Creator Applications ──────────────────────────────────────────────
enum CreatorType {
  ARTIST
  LABEL
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

model CreatorApplication {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         CreatorType
  status       ApplicationStatus @default(PENDING)
  displayName  String
  slug         String
  bio          String?           @db.Text
  genre        String?
  country      String?           @default("Nigeria")
  photo        String?
  socialLinks  Json?
  proofUrls    Json?
  reviewedById String?
  reviewedBy   User?             @relation("ApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNote   String?           @db.Text
  reviewedAt   DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([status, createdAt])
  @@index([userId])
}

// ── Albums ────────────────────────────────────────────────────────────
model Album {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  coverArt    String?
  releaseDate DateTime?
  type        AlbumType @default(ALBUM)
  genre       String?
  label       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  artistId String
  artist   Artist  @relation(fields: [artistId], references: [id])
  tracks   Music[]

  @@index([slug])
}

enum AlbumType {
  ALBUM
  EP
  MIXTAPE
  COMPILATION
}

// ── Downloads ─────────────────────────────────────────────────────────
model Download {
  id        String   @id @default(cuid())
  ip        String
  userAgent String?
  country   String?
  createdAt DateTime @default(now())

  musicId String
  music   Music   @relation(fields: [musicId], references: [id])
  userId  String?
  user    User?   @relation(fields: [userId], references: [id])

  @@index([musicId])
  @@index([userId, createdAt])
  @@index([createdAt])
}

// ── Categories & Tags ─────────────────────────────────────────────────
model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?
  color       String?
  icon        String?
  sortOrder   Int     @default(0)
  posts       Post[]

  @@index([slug])
  @@index([sortOrder])
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @unique
  slug  String    @unique
  posts PostTag[]

  @@index([slug])
}

model PostTag {
  postId String
  tagId  String
  post   Post   @relation(fields: [postId], references: [id])
  tag    Tag    @relation(fields: [tagId], references: [id])

  @@id([postId, tagId])
}

// ── Comments ──────────────────────────────────────────────────────────
model Comment {
  id        String        @id @default(cuid())
  body      String
  status    CommentStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Guest comment fields (used when authorId is null)
  guestName    String?
  guestEmail   String?
  guestWebsite String?

  postId   String
  post     Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId String?
  author   User?         @relation(fields: [authorId], references: [id], onDelete: SetNull)
  parentId String?
  parent   Comment?      @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[]     @relation("CommentReplies")
  likes    CommentLike[]

  @@index([postId, status])
  @@index([authorId])
}

// ── Comment Likes ────────────────────────────────────────────────────
model CommentLike {
  id        String   @id @default(cuid())
  type      String // "LIKE" | "DISLIKE"
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
  @@index([commentId, type])
}

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
  SPAM
}

// ── Newsletter ────────────────────────────────────────────────────────
model Subscriber {
  id                String           @id @default(cuid())
  email             String           @unique
  name              String?
  status            SubscriberStatus @default(PENDING)
  confirmationToken String?          @unique
  tokenExpiresAt    DateTime?
  confirmedAt       DateTime?
  createdAt         DateTime         @default(now())
}

enum SubscriberStatus {
  PENDING
  CONFIRMED
  UNSUBSCRIBED
}

// ── NextAuth ──────────────────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

// ── Site Settings (singleton – one row with id="default") ───────────
model SiteSettings {
  id        String   @id @default("default")
  updatedAt DateTime @updatedAt

  // General / Site Identity
  siteName       String  @default("Soundloaded Blog")
  tagline        String  @default("Nigeria's #1 music download & entertainment blog")
  siteUrl        String  @default("https://soundloaded.ng")
  contactEmail   String  @default("")
  copyrightText  String  @default("Soundloaded Nigeria. All rights reserved.")
  logoLight      String? // R2 key
  logoDark       String? // R2 key
  favicon        String? // R2 key
  defaultOgImage String? // R2 key (1200x630)

  // SEO & Meta
  metaTitleTemplate      String @default("%s | Soundloaded Blog")
  metaDescription        String @default("Nigeria's premier music blog — latest music news, free music downloads, gist, artist profiles, and more.")
  googleSiteVerification String @default("")
  bingSiteVerification   String @default("")
  googleAnalyticsId      String @default("")
  seoKeywords            String @default("Nigeria music, Afrobeats, free music download, music news, African music")

  // Social Links
  instagram  String @default("soundloadedng")
  twitter    String @default("soundloadedng")
  facebook   String @default("soundloadedng")
  youtube    String @default("")
  spotify    String @default("")
  tiktok     String @default("")
  appleMusic String @default("")
  telegram   String @default("")
  whatsapp   String @default("")

  // PWA
  pwaAppName         String @default("Soundloaded Blog")
  pwaShortName       String @default("Soundloaded")
  pwaThemeColor      String @default("#e11d48")
  pwaBackgroundColor String @default("#0a0a0a")
  pwaDisplayMode     String @default("standalone")
  pwaOrientation     String @default("any")
  pwaIcons           Json   @default("[]")
  pwaSplashScreens   Json   @default("[]")

  // Notifications
  discordWebhookUrl      String  @default("")
  notifyOnNewComment     Boolean @default(true)
  notifyOnNewSubscriber  Boolean @default(true)
  notifyOnNewMusicUpload Boolean @default(false)
  notifyOnPublish        Boolean @default(false)

  // Social Auto-Sharing
  autoShareTwitter        Boolean @default(false)
  autoShareTelegram       Boolean @default(false)
  telegramBotToken        String  @default("")
  telegramChatId          String  @default("")
  emailNotificationsAdmin Boolean @default(true)

  // Content / Reading
  postsPerPage           Int     @default(20)
  feedItemCount          Int     @default(20)
  feedContentMode        String  @default("excerpt") // "full" | "excerpt"
  searchEngineVisibility Boolean @default(true) // false = adds noindex
  defaultPostStatus      String  @default("DRAFT")
  enableDownloads        Boolean @default(true)
  maxDownloadsPerHour    Int     @default(10)

  // Permalinks
  permalinkStructure String @default("/%postname%") // e.g. "/%category%/%postname%"
  categoryBase       String @default("category") // prefix for category archive pages

  // Discussion / Comments
  enableComments            Boolean @default(true)
  autoApproveComments       Boolean @default(false)
  requireLoginToComment     Boolean @default(false)
  commentNestingDepth       Int     @default(2) // 1–5 levels
  commentsPerPage           Int     @default(20)
  commentOrder              String  @default("oldest") // "oldest" | "newest"
  closeCommentsAfterDays    Int     @default(0) // 0 = never
  commentPreviouslyApproved Boolean @default(false) // require prior approved comment
  commentMaxLinks           Int     @default(2) // hold if N+ links, 0 = disabled
  emailOnNewComment         Boolean @default(true)
  emailOnModeration         Boolean @default(true)
  commentModerationKeywords String  @default("") @db.Text
  commentBlocklist          String  @default("") @db.Text

  // Locale
  timezone   String @default("Africa/Lagos")
  dateFormat String @default("MMM d, yyyy")
  timeFormat String @default("h:mm a")
  language   String @default("en")

  // Maintenance
  maintenanceMode       Boolean @default(false)
  maintenanceMessage    String  @default("We're upgrading. Be right back!") @db.Text
  maintenanceAllowedIPs String  @default("")

  // Code Injection
  headerScripts String @default("") @db.Text
  footerScripts String @default("") @db.Text

  // Media
  thumbnailSize     Int     @default(150)
  mediumImageSize   Int     @default(600)
  largeImageSize    Int     @default(1200)
  imageQuality      Int     @default(80)
  enableWatermark   Boolean @default(false)
  watermarkImage    String?
  watermarkPosition String  @default("bottom-right")

  // Security
  maxLoginAttempts       Int     @default(5)
  loginLockoutDuration   Int     @default(15)
  requireStrongPasswords Boolean @default(true)
  allowRegistration      Boolean @default(true)
  defaultUserRole        String  @default("READER")
  enableTurnstile        Boolean @default(true)  // Cloudflare Turnstile bot protection on login/register

  // Email
  emailFromName       String  @default("Soundloaded Blog")
  emailFromAddress    String  @default("")
  emailWelcomeEnabled Boolean @default(true)
  emailDigestEnabled  Boolean @default(false)
  emailDigestDay      String  @default("monday")

  // Appearance
  brandColor     String  @default("#e11d48")
  enableDarkMode Boolean @default(true)
  defaultTheme   String  @default("dark")
  customCss      String  @default("") @db.Text

  // Feature Toggles — Stories
  enableStories    Boolean @default(true)
  storyExpiryHours Int     @default(24)

  // Feature Toggles — Site Sections
  enableFeed    Boolean @default(true)
  enableExplore Boolean @default(true)
  enableMusic   Boolean @default(true)
  enableNews    Boolean @default(true)
  enableGist    Boolean @default(true)
  enableLyrics  Boolean @default(true)
  enableVideos  Boolean @default(true)
  enableAlbums  Boolean @default(true)
  enableArtists Boolean @default(true)
  enableSearch  Boolean @default(true)

  // Feature Toggles — Player Experience
  enableNowPlayingDrawer Boolean @default(true)

  // Billing & Monetization
  creatorRevenuePercent     Int     @default(70)    // % of revenue paid to creators
  enableCreatorMonetization Boolean @default(false) // allow creators to set access model
  freeDownloadQuota         Int     @default(5)     // monthly free downloads on Free plan
  paystackPublicKey         String  @default("")    // publishable key for frontend
}

// ── Media Library ────────────────────────────────────────────────────
enum MediaType {
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
}

model Media {
  id            String    @id @default(cuid())
  filename      String
  r2Key         String    @unique
  url           String
  mimeType      String
  size          Int
  width         Int?
  height        Int?
  alt           String    @default("")
  title         String    @default("")
  caption       String    @default("")
  folder        String    @default("")
  type          MediaType @default(IMAGE)
  uploadedBy    String?
  user          User?     @relation(fields: [uploadedBy], references: [id])
  postDownloads Post[]    @relation("PostDownloadMedia")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([type])
  @@index([folder])
  @@index([createdAt])
}

// ── Push Notifications ──────────────────────────────────────────────
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

// ── Search Analytics ─────────────────────────────────────────────────
model SearchQuery {
  id        String   @id @default(cuid())
  query     String
  results   Int      @default(0) // total hits returned
  engine    String   @default("meilisearch") // "meilisearch" or "postgresql"
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  ip        String?
  createdAt DateTime @default(now())

  @@index([query])
  @@index([userId, createdAt])
  @@index([query, createdAt])
  @@index([createdAt])
}

// ── Recommendation Events & Snapshots ────────────────────────────────
enum RecommendationEntityType {
  POST
  MUSIC
  ARTIST
  PLAYLIST
  USER
  STORY
  SEARCH_QUERY
}

enum RecommendationSurface {
  FEED_FORYOU
  FEED_FOLLOWING
  FEED_DISCOVER
  EXPLORE_LATEST
  EXPLORE_TOP
  EXPLORE_TRENDING
  EXPLORE_HOT
  POST_DETAIL
  MUSIC_DETAIL
  ARTIST_DETAIL
  PLAYLIST_DETAIL
  SEARCH_RESULTS
  SEARCH_TRENDING
  FOLLOW_SUGGESTIONS
  LIBRARY_PLAYLIST
  STORIES_VIEWER
}

enum RecommendationEventName {
  POST_IMPRESSION
  POST_VIEW
  POST_REACTION_ADD
  POST_REACTION_REMOVE
  POST_COMMENT_CREATE
  POST_BOOKMARK_ADD
  POST_FAVORITE_ADD
  POST_DOWNLOAD
  POST_HIDE
  MUSIC_IMPRESSION
  MUSIC_PLAY_QUALIFIED
  MUSIC_DOWNLOAD
  MUSIC_BOOKMARK_ADD
  MUSIC_FAVORITE_ADD
  MUSIC_PLAYLIST_ADD
  MUSIC_DETAIL_OPEN
  ARTIST_FOLLOW
  ARTIST_UNFOLLOW
  ARTIST_DETAIL_OPEN
  PLAYLIST_OPEN
  PLAYLIST_TRACK_ADD
  PLAYLIST_REORDER
  USER_FOLLOW
  USER_UNFOLLOW
  STORY_VIEW
  SEARCH_QUERY
  SEARCH_NO_RESULT
  SEARCH_RESULT_CLICK
  RECOMMENDATION_IMPRESSION
  RECOMMENDATION_CLICK
  RECOMMENDATION_DISMISS
}

enum AffinityDimensionType {
  CATEGORY
  TAG
  ARTIST
  GENRE
  AUTHOR
  POST_TYPE
}

model InteractionEvent {
  id         String                   @id @default(cuid())
  eventName  RecommendationEventName
  entityType RecommendationEntityType
  entityId   String?

  userId      String?
  user        User?   @relation("InteractionEventUser", fields: [userId], references: [id], onDelete: SetNull)
  anonymousId String?
  sessionId   String?

  surface    RecommendationSurface
  placement  String?
  position   Int?
  occurredAt DateTime              @default(now())

  recommendationRequestId String?
  candidateSource         String?
  reasonKey               String?

  referrerEntityType RecommendationEntityType?
  referrerEntityId   String?
  queryText          String?
  artistId           String?
  albumId            String?
  categoryId         String?
  tagSlug            String?
  genre              String?
  weightHint         Float?
  metadata           Json?
  dedupeKey          String?
  createdAt          DateTime                  @default(now())

  @@unique([dedupeKey])
  @@index([userId, occurredAt])
  @@index([anonymousId, occurredAt])
  @@index([entityType, entityId, occurredAt])
  @@index([eventName, occurredAt])
  @@index([surface, occurredAt])
  @@index([recommendationRequestId])
}

model RecommendationImpression {
  id        String @id @default(cuid())
  requestId String

  userId      String?
  user        User?   @relation("RecommendationImpressionUser", fields: [userId], references: [id], onDelete: SetNull)
  anonymousId String?
  sessionId   String?

  surface         RecommendationSurface
  strategy        String
  entityType      RecommendationEntityType
  entityId        String
  position        Int
  candidateSource String?
  reasonKey       String?
  score           Float?
  servedAt        DateTime                 @default(now())
  metadata        Json?

  @@index([requestId, position])
  @@index([userId, surface, servedAt])
  @@index([anonymousId, surface, servedAt])
  @@index([entityType, entityId, servedAt])
}

model UserAffinitySnapshot {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  dimensionType AffinityDimensionType
  dimensionKey  String
  score         Float
  eventCount    Int                   @default(0)
  windowDays    Int
  lastEventAt   DateTime?
  metadata      Json?
  updatedAt     DateTime              @updatedAt
  createdAt     DateTime              @default(now())

  @@unique([userId, dimensionType, dimensionKey, windowDays])
  @@index([userId, dimensionType, score])
}

// ── Payments ──────────────────────────────────────────────────────────
enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

model Plan {
  id                      String         @id @default(cuid())
  name                    String         // e.g. "Free", "Standard", "Pro"
  slug                    String         @unique // "free" | "standard" | "pro"
  priceMonthly            Int            @default(0)  // kobo
  priceYearly             Int            @default(0)  // kobo
  paystackPlanCodeMonthly String?        // Paystack plan_code for monthly billing
  paystackPlanCodeYearly  String?        // Paystack plan_code for yearly billing
  features                Json           @default("[]") // string[] — bullet points
  downloadQuota           Int            @default(5)  // monthly download limit (0 = unlimited)
  isActive                Boolean        @default(true)
  sortOrder               Int            @default(0)
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  subscriptions Subscription[]

  @@index([slug])
  @@index([isActive, sortOrder])
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String             @unique
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  paystackSubCode  String?            @unique
  paystackCustCode String?
  plan             String             @default("monthly") // kept for backwards compat
  planId           String?            // FK to Plan table
  planRef          Plan?              @relation(fields: [planId], references: [id])
  status           SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([userId])
  @@index([planId])
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String // "subscription" | "download"
  amount      Int // kobo (smallest NGN unit)
  currency    String   @default("NGN")
  paystackRef String   @unique
  status      String // "success" | "failed" | "pending"
  musicId     String?
  music       Music?   @relation(fields: [musicId], references: [id])
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([paystackRef])
}

// ── Bookmarks ──────────────────────────────────────────────────────────
model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  musicId   String?
  music     Music?   @relation(fields: [musicId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@unique([userId, musicId])
  @@index([userId, createdAt])
  @@index([postId, createdAt])
  @@index([musicId, createdAt])
}

// ── Favorites ──────────────────────────────────────────────────────────
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  musicId   String?
  music     Music?   @relation(fields: [musicId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@unique([userId, musicId])
  @@index([userId, createdAt])
  @@index([postId, createdAt])
  @@index([musicId, createdAt])
}

// ── Reactions ──────────────────────────────────────────────────────────
model Reaction {
  id        String   @id @default(cuid())
  emoji     String   @default("❤️")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([postId, emoji])
  @@index([postId, createdAt])
  @@index([userId, createdAt])
}

// ── Notifications ──────────────────────────────────────────────────────
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation("NotificationsReceived", fields: [userId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?            @relation("NotificationsTriggered", fields: [actorId], references: [id], onDelete: SetNull)
  type      NotificationType
  title     String
  body      String
  link      String?
  read      Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  @@index([userId, read, createdAt])
  @@index([actorId])
}

enum NotificationType {
  COMMENT_REPLY
  NEW_MUSIC
  SUBSCRIPTION_REMINDER
  SYSTEM
  DOWNLOAD_READY
  REPORT_FILED
  REPORT_UPDATE
  NEW_FOLLOWER
  REACTION
  NEW_COMMENT
  APPLICATION_SUBMITTED
  APPLICATION_APPROVED
  APPLICATION_REJECTED
}

// ── User Preferences ──────────────────────────────────────────────────
model UserPreferences {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pushEnabled         Boolean  @default(true)
  emailDigest         Boolean  @default(false)
  emailCommentReplies Boolean  @default(true)
  emailNewMusic       Boolean  @default(false)
  emailNewsletter     Boolean  @default(true)
  emailMarketing      Boolean  @default(false)
  showProfile         Boolean  @default(true)
  showDownloadHistory Boolean  @default(false)
  themePreference     String   @default("system")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ── Follow ────────────────────────────────────────────────────────────
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@index([followingId, createdAt])
}

model ArtistFollow {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  artistId  String
  artist    Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, artistId])
  @@index([userId])
  @@index([artistId])
  @@index([artistId, createdAt])
}

// ── Stories ───────────────────────────────────────────────────────────
enum StoryItemType {
  IMAGE
  VIDEO
  GIF
  TEXT
}

model Story {
  id        String      @id @default(cuid())
  authorId  String
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  items     StoryItem[]
  createdAt DateTime    @default(now())
  expiresAt DateTime

  @@index([authorId, expiresAt])
  @@index([expiresAt])
}

model StoryItem {
  id        String        @id @default(cuid())
  storyId   String
  story     Story         @relation(fields: [storyId], references: [id], onDelete: Cascade)
  type      StoryItemType @default(IMAGE)
  mediaUrl  String
  caption   String?
  duration  Int           @default(5)
  order     Int           @default(0)
  views     StoryView[]
  createdAt DateTime      @default(now())

  // Audio overlay (TEXT and IMAGE stories only)
  audioUrl       String?
  audioStartTime Float?  @default(0)
  audioEndTime   Float?  @default(30)

  // Text story fields
  backgroundColor String?
  textContent     String?

  @@index([storyId, order])
}

model StoryView {
  id          String    @id @default(cuid())
  storyItemId String
  storyItem   StoryItem @relation(fields: [storyItemId], references: [id], onDelete: Cascade)
  viewerId    String
  viewer      User      @relation(fields: [viewerId], references: [id], onDelete: Cascade)
  viewedAt    DateTime  @default(now())

  @@unique([storyItemId, viewerId])
  @@index([storyItemId])
}

// ── Hidden Posts ──────────────────────────────────────────────────────
model HiddenPost {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([userId, createdAt])
}

// ── Post Views (Facebook-style: deduped per user, 24h window) ────────
model PostView {
  id       String   @id @default(cuid())
  postId   String
  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  viewerId String
  viewer   User     @relation(fields: [viewerId], references: [id], onDelete: Cascade)
  viewedAt DateTime @default(now())

  @@unique([postId, viewerId])
  @@index([postId])
  @@index([postId, viewedAt])
  @@index([viewerId, viewedAt])
}

// ── Reports ──────────────────────────────────────────────────────────
model Report {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId     String
  post       Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  reason     String // "spam" | "harassment" | "misinformation" | "hate_speech" | "violence" | "other"
  details    String?      @db.Text
  status     ReportStatus @default(PENDING)
  adminNote  String?      @db.Text
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([status, createdAt])
  @@index([postId])
  @@index([userId])
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
  ACTION_TAKEN
}

// ── User Blocks & Mutes ──────────────────────────────────────────────
model UserBlock {
  id        String    @id @default(cuid())
  blockerId String
  blocker   User      @relation("UserBlocking", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User      @relation("UserBlocked", fields: [blockedId], references: [id], onDelete: Cascade)
  type      BlockType @default(BLOCK)
  createdAt DateTime  @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

enum BlockType {
  BLOCK
  MUTE
}

// ── Playlists ─────────────────────────────────────────────────────────
model Playlist {
  id          String          @id @default(cuid())
  title       String
  slug        String
  description String?
  coverImage  String?
  isPublic    Boolean         @default(false)
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks      PlaylistTrack[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([userId, slug])
  @@index([userId, updatedAt])
  @@index([isPublic, updatedAt])
}

model PlaylistTrack {
  id         String   @id @default(cuid())
  playlistId String
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  musicId    String
  music      Music    @relation(fields: [musicId], references: [id], onDelete: Cascade)
  position   Int
  addedAt    DateTime @default(now())

  @@unique([playlistId, musicId])
  @@index([playlistId, position])
  @@index([musicId, addedAt])
}

// ── Audio Processing Jobs ─────────────────────────────────────────────
model AudioProcessingJob {
  id          String    @id @default(cuid())
  musicId     String
  music       Music     @relation(fields: [musicId], references: [id], onDelete: Cascade)
  jobType     String // transcode | normalize | waveform | full
  status      String    @default("pending") // pending | processing | completed | failed
  priority    Int       @default(0)
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  error       String?
  result      Json? // output metadata from FFmpeg
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, priority, createdAt])
  @@index([musicId])
}
